# .gitignore
# Based on the Godot template from GitHub's gitignore repository
# Source: https://github.com/github/gitignore/blob/main/Godot.gitignore
# License: CC0-1.0

# Godot 4+ specific ignores
.godot/
.nomedia

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg
*.tmp

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json